# ─────────────────────────────────────────────────────────────────────────────
# Berlin Job Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key...

# The JWT secret is used by Django to verify Supabase tokens server-side.
# Found in: Supabase dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret


# ── Django ────────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-django-secret-key-here

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origin for CORS (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000


# ── Postgres (Supabase connection string) ─────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → Database → Connection parameters

POSTGRES_HOST=db.YOUR_PROJECT_REF.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password
POSTGRES_SSLMODE=require


# ── Crawler / DeepSeek ───────────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com

DEEPSEEK_API_KEY=sk-...your-deepseek-key...


# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Where the Django API lives (used only for saved-jobs endpoints)
# In production this should be your Railway/backend public URL

VITE_API_BASE_URL=http://localhost:8000
